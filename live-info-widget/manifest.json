{
  "id": "live-info-widget",
  "name": "Widget de Reloj y Clima",
  "description": "Información en vivo de hora y temperatura para esquinas de pantalla. Ideal para transmisiones deportivas y eventos.",
  "version": "4.1.5",
  "author": "Jonatan Barón",
  "presets": ["branding", "motion", "layout"],
  "schema": [
    { "id": "location", "type": "string", "label": "Ubicación",    "defaultValue": "MADRID, ES" },
    { "id": "temp",     "type": "string", "label": "Temperatura",  "defaultValue": "22°C" },
    { "id": "weatherIcon", "type": "select", "label": "Clima", "defaultValue": "sunny",
      "options": [
        { "label": "☀️ Soleado",   "value": "sunny" },
        { "label": "☁️ Nublado",   "value": "cloudy" },
        { "label": "🌧️ Lluvia",    "value": "rain" },
        { "label": "❄️ Nieve",     "value": "snow" }
      ]
    }
  ]
}
