{
  "id": "social-cards-pro",
  "name": "Tarjetas de Redes Sociales Pro",
  "description": "Animación de entrada con efecto bounce para perfiles de redes sociales. Soporta Instagram, X, YouTube y Twitch.",
  "version": "4.1.5",
  "author": "Jonatan Barón",
  "presets": ["branding", "motion", "layout"],
  "schema": [
    {
      "id": "platform",
      "type": "select",
      "label": "Plataforma",
      "defaultValue": "instagram",
      "options": [
        { "label": "Instagram", "value": "instagram" },
        { "label": "X (Twitter)", "value": "twitter" },
        { "label": "YouTube", "value": "youtube" },
        { "label": "Twitch", "value": "twitch" }
      ]
    },
    {
      "id": "username",
      "type": "string",
      "label": "Nombre de Usuario",
      "defaultValue": "@usuario_pro"
    }
  ]
}
